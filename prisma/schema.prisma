generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobApplication {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  // Company & Position info
  companyName   String
  position      String
  jobUrl        String?
  location      String?
  jobType       String?  // "remote" | "onsite" | "hybrid"

  // Application source & tracking
  source        String   // "LinkedIn", "Facebook", "Company Website", "Referral" etc
  appliedDate   DateTime @default(now())

  // Salary
  salaryRange   String?  // e.g. "50k-70k", "Negotiable", "৳40,000 - ৳60,000"

  // Status tracking
  status        String   @default("applied") 
  // possible values: applied, interview, offer, rejected, accepted, withdrawn

  // Interview tracking (optional)
  interviewDate DateTime?

  // Notes / extra info
  notes         String?
  contactPerson String?
  contactEmail  String?

  // Relation to User
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("job_applications")
}

